
NEXT_PUBLIC_API_URL=http://localhost:8000

# Error tracking (issue #334, Optional). Unset => Sentry is inert. Set to your
# Sentry project's DSN to route client + server errors to Sentry instead of the
# console. NEXT_PUBLIC_ is inlined at build time, so it must be present when the
# app is built. Get from: Sentry project settings -> Client Keys (DSN).
NEXT_PUBLIC_SENTRY_DSN=

# Better Auth Configuration
# CRITICAL: Must match backend BETTER_AUTH_SECRET exactly
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
BETTER_AUTH_SECRET=your-secure-secret-key-here-replace-with-generated-value
# Base URL for better-auth API endpoints
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Database Configuration (MongoDB for better-auth)
DATABASE_URL=mongodb://localhost:27017/auto_author
DATABASE_NAME=auto_author

# Transactional Email (password reset — #332)
# REQUIRED in staging/production or account recovery silently fails: the reset
# flow shows "Check your email" but no email is sent. Set these as staging/prod
# secrets. In local development, leaving EMAIL_SERVICE_PROVIDER unset (or =console)
# dumps the reset email to the server console instead of sending.
#   Provider: 'resend' (recommended) or 'sendgrid'
EMAIL_SERVICE_PROVIDER=
#   API key for the chosen provider
EMAIL_SERVICE_API_KEY=
#   From address (must be a verified sender/domain with the provider)
EMAIL_FROM_ADDRESS=noreply@autoauthor.app
#   Optional display name on the From header (defaults to "Auto Author")
# EMAIL_FROM_NAME=Auto Author

# E2E Testing Configuration (Development Only)
# SECURITY: This is a server-side only variable (NOT NEXT_PUBLIC_)
# NEVER set to true in production - application will throw fatal error
# Set to true only for E2E testing to bypass authentication
BYPASS_AUTH=false
# Purpose-built opt-in required alongside BYPASS_AUTH in EVERY environment
# (#272): BYPASS_AUTH=true alone never bypasses auth. Playwright's webServer
# config sets this automatically; set it by hand only for manual dev-server
# bypass workflows. Never set in real deploys.
E2E_ALLOW_BYPASS=0
