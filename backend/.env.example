# Database settings
# For local MongoDB (development/testing):
DATABASE_URL=mongodb://localhost:27017
DATABASE_NAME=auto_author_test

# For MongoDB Atlas (cloud production):
# Use mongodb+srv:// protocol which automatically enables TLS/SSL
# Example: mongodb+srv://<username>:<password>@<cluster>.mongodb.net
# Note: SSL/TLS is automatically configured using the certifi package for certificate validation
# This ensures secure connections and compatibility with Python 3.13+ strict SSL requirements

# CORS Settings
# Can be a comma-separated string or JSON array
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# OpenAI API key (Required)
# Get from: https://platform.openai.com/api-keys
OPENAI_AUTOAUTHOR_API_KEY=sk-your-openai-api-key-here

# Better Auth Configuration (Required)
# CRITICAL: BETTER_AUTH_SECRET is required and must be a strong random value
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
# NEVER use default/weak values - application will reject them
# Minimum 32 characters, recommended 64+ for production
BETTER_AUTH_SECRET=your-secure-secret-key-here-replace-with-generated-value
# Base URL of the application (must match frontend URL)
BETTER_AUTH_URL=http://localhost:3000
# Issuer identifier for JWT tokens
BETTER_AUTH_ISSUER=better-auth

# API Settings
API_V1_PREFIX=/api/v1

# E2E Testing Settings
# WARNING: NEVER enable in production - application will refuse to start
# Only for development/test environments to bypass authentication in E2E tests
# When enabled, all API endpoints return a mock test user without requiring JWT
BYPASS_AUTH=false
# Purpose-built opt-in required alongside BYPASS_AUTH in EVERY non-production
# environment (#307): BYPASS_AUTH=true alone is coerced off with a warning.
# Only the exact value 1 counts. Never set in real deploys (production stays
# hard-blocked regardless).
E2E_ALLOW_BYPASS=0

# Plan/entitlement enforcement (issue #174). When true, AI endpoints check the
# caller's plan against the entitlement registry. Free beta users get full
# access, so this is safe to leave on; bypassed alongside BYPASS_AUTH.
PLAN_ENFORCEMENT_ENABLED=true

# AWS Settings (Optional - for transcription and S3 storage)
# Leave empty if not using AWS services (will fallback to local storage)
# Get from: https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Cloudinary Settings (Optional - for image storage)
# Leave empty if not using Cloudinary (will fallback to local storage)
# Get from: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe billing (issues #220/#221, Optional until paid launch)
# STRIPE_WEBHOOK_SECRET verifies webhook payloads (raw-body HMAC); leave empty
# to keep POST /api/v1/webhooks/stripe failing closed (503).
# Get from: https://dashboard.stripe.com/webhooks (signing secret, whsec_...)
STRIPE_WEBHOOK_SECRET=
# Stripe price id that maps subscribers to the "pro" plan
STRIPE_PRICE_ID_PRO=
# Stripe API secret key (sk_test_.../sk_live_...) used by POST /api/v1/billing/checkout;
# leave empty to keep checkout failing closed (503).
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Maximum number of retry attempts for failed AI service calls
# The service uses exponential backoff between retries
# Default: 3
AI_MAX_RETRIES=3
